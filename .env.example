# Optional: secret for admin endpoints (X-Admin-Secret header)
# ADMIN_SECRET=your_admin_secret

# Stripe (required for Pro plan billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
